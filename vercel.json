{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/translate",
      "dest": "main.py"
    },
    {
      "src": "/languages",
      "dest": "main.py"
    },
    {
      "src": "/translate-document",
      "dest": "main.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}